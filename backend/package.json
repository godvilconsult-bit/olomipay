{
  "name": "olomipay-backend",
  "version": "3.0.0",
  "description": "Tuma API — M-Pesa × Stellar bridge + chat + financial services",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "prisma generate && tsc --skipLibCheck --noEmitOnError false || true",
    "start": "node dist/index.js",
    "postinstall": "prisma generate",
    "db:migrate": "prisma migrate dev",
