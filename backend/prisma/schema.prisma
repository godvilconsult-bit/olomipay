generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ──────────────────────────────────────────────────────────────────────

enum KycStatus {
  PENDING
  SUBMITTED
  APPROVED
  REJECTED
}

enum TxType {
  DEPOSIT
  WITHDRAWAL
  SEND
  RECEIVE
  FEE
  SAVINGS_DEPOSIT
  SAVINGS_WITHDRAW
  BILL_PAYMENT
  BANK_WITHDRAWAL
}

enum TxStatus {
  PENDING
  CONFIRMED
  FAILED
  EXPIRED
}

enum Frequency {
  DAILY
  WEEKLY
  BIWEEKLY
  MONTHLY
}

enum ClaimStatus {
  PENDING
  CLAIMED
  EXPIRED
  RETURNED
}

enum StakeStatus {
  ACTIVE
  UNLOCKED
  WITHDRAWN
}

enum ConvType {
  DIRECT
  GROUP
}

enum MessageType {
  TEXT
  PAYMENT
  PAYMENT_REQUEST
  IMAGE
  SYSTEM
}

enum PaymentStatus {
  PENDING
  CONFIRMED
  FAILED
  EXPIRED
}

enum ChamaStatus {
  FORMING
  ACTIVE
  COMPLETED
  PAUSED
}

enum LoanStatus {
  OPEN
  FUNDED
  REPAID
  DEFAULTED
}

enum RewardTier {
  BRONZE
  SILVER
  GOLD
  PLATINUM
}

enum BusinessPlan {
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

enum BondStatus {
  OPEN
  CLOSED
  MATURED
  REDEEMED
}

enum Country {
  TZ
  KE
  UG
  RW
  ZM
}

// ── Core models ───────────────────────────────────────────────────────────────

model User {
  id              String    @id @default(cuid())
  phone           String    @unique
  pinHash         String
  stellarPubKey   String    @unique
  stellarSecret   String
  kycStatus       KycStatus @default(PENDING)
  kycName         String?
  kycIdType       String?
  kycIdNumber     String?
  dailyVolumeTzs  Float     @default(0)
  dailyVolumeDate DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  transactions       Transaction[]
  refreshTokens      RefreshToken[]
  bankAccounts       BankAccount[]
  savingsPosition    SavingsPosition?
  billPayments       BillPayment[]
  scheduledPayments  ScheduledPayment[]
  pushSubscriptions  PushSubscription[]
  notifications      Notification[]
  stakePosition      StakePosition?
  chamasAdmin        Chama[]
  chamaMembers       ChamaMember[]
  loansGiven         LoanListing[]     @relation("LenderLoans")
  loansTaken         LoanListing[]     @relation("BorrowerLoans")
  creditScore        CreditScore?
  rewardPoints       RewardPoints?
  virtualCard        VirtualCard?
  merchant           Merchant?
  bondHoldings       BondHolding[]
  devApiKeys         DevApiKey[]
  country            Country           @default(TZ)
  chatPublicKey      String?
  chatSecretKeyEnc   String?
  isOnline           Boolean           @default(false)
  lastSeenAt         DateTime?
  chatMembers        ConversationMember[]
  sentMessages       Message[]
  messageReceipts    MessageReceipt[]
  blockedUsers       BlockedUser[]     @relation("Blocker")
  blockedBy          BlockedUser[]     @relation("Blocked")
}

model Transaction {
  id          String   @id @default(cuid())
  userId      String
  type        TxType
  status      TxStatus @default(PENDING)
  amountTzs   Float?
  amountUsdc  Float?
  amountXlm   Float?
  stellarTxId String?
  mpesaTxId   String?
  toAddress   String?
  memo        String?
  errorMsg    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([mpesaTxId])
  @@index([stellarTxId])
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ExchangeRateCache {
  id        String   @id @default("singleton")
  usdToTzs  Float
  updatedAt DateTime @updatedAt
}

// ── Feature 1: Bank Withdrawal ────────────────────────────────────────────────

model BankAccount {
  id            String   @id @default(cuid())
  userId        String
  bankName      String
  accountNumber String
  swiftCode     String
  accountName   String
  isVerified    Boolean  @default(false)
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

// ── Feature 2: Savings ────────────────────────────────────────────────────────

model SavingsPosition {
  id           String    @id @default(cuid())
  userId       String    @unique
  principal    Float     @default(0)
  yieldEarned  Float     @default(0)
  depositedAt  DateTime?
  lastYieldAt  DateTime?
  user         User      @relation(fields: [userId], references: [id])
}

// ── Feature 3: Bill Payments ──────────────────────────────────────────────────

model BillPayment {
  id            String   @id @default(cuid())
  userId        String
  billerName    String
  billerCode    String
  accountNumber String
  amountTzs     Float
  amountUsdc    Float
  reference     String?
  token         String?  // LUKU electricity token
  status        TxStatus @default(PENDING)
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

// ── Feature 4: Contacts / Pending Claims ─────────────────────────────────────

model PendingClaim {
  id         String      @id @default(cuid())
  senderId   String
  toPhone    String
  claimToken String      @unique
  amountUsdc Float
  expiresAt  DateTime
  claimedAt  DateTime?
  status     ClaimStatus @default(PENDING)
  createdAt  DateTime    @default(now())

  @@index([claimToken])
  @@index([toPhone])
}

// ── Feature 5: Scheduled Payments ────────────────────────────────────────────

model ScheduledPayment {
  id             String    @id @default(cuid())
  userId         String
  toAddress      String
  toPhone        String?
  toName         String?
  amount         Float
  asset          String    @default("USDC")
  frequency      Frequency
  nextRunAt      DateTime
  endDate        DateTime?
  memo           String?
  isActive       Boolean   @default(true)
  executionCount Int       @default(0)
  lastRunAt      DateTime?
  createdAt      DateTime  @default(now())
  user           User      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([nextRunAt, isActive])
}

// ── Feature 6: Push Notifications ────────────────────────────────────────────

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dhKey String
  authKey   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  body      String
  type      String
  isRead    Boolean  @default(false)
  data      Json?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([userId, createdAt])
}

// ── Phase 3 Models ────────────────────────────────────────────────────────────

model StakePosition {
  id           String      @id @default(cuid())
  userId       String      @unique
  amountUsdc   Float
  lockDays     Int
  apyBps       Int
  stakedAt     DateTime
  unlockAt     DateTime
  yieldClaimed Float       @default(0)
  contractKey  String?
  status       StakeStatus @default(ACTIVE)
  user         User        @relation(fields: [userId], references: [id])
}

model Chama {
  id               String      @id @default(cuid())
  name             String
  contractId       String?
  adminId          String
  contributionUsdc Float
  frequencyDays    Int
  currentRound     Int         @default(0)
  status           ChamaStatus @default(FORMING)
  nextDueAt        DateTime?
  createdAt        DateTime    @default(now())
  members          ChamaMember[]
  admin            User        @relation(fields: [adminId], references: [id])
}

model ChamaMember {
  id          String  @id @default(cuid())
  chamaId     String
  userId      String
  position    Int
  hasReceived Boolean @default(false)
  chama       Chama   @relation(fields: [chamaId], references: [id])
  user        User    @relation(fields: [userId], references: [id])

  @@unique([chamaId, userId])
  @@index([chamaId])
}

model LoanListing {
  id           String     @id @default(cuid())
  lenderId     String
  amountUsdc   Float
  interestBps  Int
  durationDays Int
  status       LoanStatus @default(OPEN)
  borrowerId   String?
  contractLoanId Int?
  createdAt    DateTime   @default(now())
  dueAt        DateTime?
  lender       User       @relation("LenderLoans",   fields: [lenderId],   references: [id])
  borrower     User?      @relation("BorrowerLoans", fields: [borrowerId], references: [id])

  @@index([status])
  @@index([lenderId])
}

model CreditScore {
  id           String   @id @default(cuid())
  userId       String   @unique
  score        Int      @default(40)
  loansRepaid  Int      @default(0)
  defaults     Int      @default(0)
  monthsActive Int      @default(0)
  updatedAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id])
}

model RewardPoints {
  id           String     @id @default(cuid())
  userId       String     @unique
  balance      Int        @default(0)
  totalEarned  Int        @default(0)
  tier         RewardTier @default(BRONZE)
  streak       Int        @default(0)
  lastActivity DateTime?
  user         User       @relation(fields: [userId], references: [id])
}

model VirtualCard {
  id           String   @id @default(cuid())
  userId       String   @unique
  cardRef      String   @unique
  maskedNumber String
  expiryMonth  Int
  expiryYear   Int
  status       String   @default("active")
  dailyLimit   Float    @default(500)
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id])
}

model RateHistory {
  id        String   @id @default(cuid())
  usdToTzs  Float
  date      DateTime @unique
  createdAt DateTime @default(now())
}

// ── Phase 4 Models ────────────────────────────────────────────────────────────

model Business {
  id          String       @id @default(cuid())
  name        String
  tin         String       @unique
  contactName String
  email       String       @unique
  phone       String
  passwordHash String
  apiKey      String       @unique @default(cuid())
  plan        BusinessPlan @default(STARTER)
  country     Country      @default(TZ)
  createdAt   DateTime     @default(now())
  payrollRuns PayrollRun[]
  govPrograms GovProgram[]
  webhooks    Webhook[]
}

model PayrollRun {
  id             String    @id @default(cuid())
  businessId     String
  totalAmount    Float
  recipientCount Int
  stellarTxId    String?
  status         TxStatus  @default(PENDING)
  csvUrl         String?
  executedAt     DateTime?
  createdAt      DateTime  @default(now())
  business       Business  @relation(fields: [businessId], references: [id])
  recipients     PayrollRecipient[]
}

model PayrollRecipient {
  id           String     @id @default(cuid())
  payrollRunId String
  name         String
  phone        String?
  address      String?
  amountUsdc   Float
  department   String?
  reference    String?
  status       TxStatus   @default(PENDING)
  stellarTxId  String?
  payrollRun   PayrollRun @relation(fields: [payrollRunId], references: [id])
}

model Merchant {
  id         String   @id @default(cuid())
  userId     String   @unique
  shopName   String
  category   String
  qrPayload  String
  totalSales Float    @default(0)
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])
}

model GovProgram {
  id           String        @id @default(cuid())
  businessId   String
  name         String
  description  String?
  budgetUsdc   Float
  disbursed    Float         @default(0)
  startDate    DateTime
  status       String        @default("active")
  createdAt    DateTime      @default(now())
  business     Business      @relation(fields: [businessId], references: [id])
  beneficiaries GovBeneficiary[]
}

model GovBeneficiary {
  id           String     @id @default(cuid())
  programId    String
  nationalId   String
  fullName     String
  phone        String
  amountUsdc   Float
  ward         String?
  district     String?
  status       TxStatus   @default(PENDING)
  reference    String     @unique @default(cuid())
  stellarTxId  String?
  disbursedAt  DateTime?
  program      GovProgram @relation(fields: [programId], references: [id])

  @@index([programId])
  @@index([nationalId])
}

model Bond {
  id             String     @id @default(cuid())
  contractBondId Int?
  name           String
  faceValueUsdc  Float
  couponRateBps  Int
  maturityDate   DateTime
  totalSupply    Float
  invested       Float      @default(0)
  minInvestment  Float
  status         BondStatus @default(OPEN)
  description    String?
  createdAt      DateTime   @default(now())
  holdings       BondHolding[]
}

model BondHolding {
  id             String   @id @default(cuid())
  bondId         String
  userId         String
  amountInvested Float
  couponClaimed  Float    @default(0)
  investedAt     DateTime @default(now())
  bond           Bond     @relation(fields: [bondId], references: [id])
  user           User     @relation(fields: [userId], references: [id])

  @@unique([bondId, userId])
}

model Webhook {
  id         String   @id @default(cuid())
  businessId String
  url        String
  events     String[]
  secret     String
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  business   Business @relation(fields: [businessId], references: [id])
}

model AuditLog {
  id         String   @id @default(cuid())
  adminId    String
  action     String
  resource   String
  resourceId String?
  metadata   Json?
  ipAddress  String
  createdAt  DateTime @default(now())

  @@index([adminId])
  @@index([createdAt])
}

model DevApiKey {
  id          String   @id @default(cuid())
  userId      String
  name        String
  keyHash     String   @unique
  lastUsedAt  DateTime?
  requestCount Int     @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
}

// ── Chat Models ───────────────────────────────────────────────────────────────

model Conversation {
  id                 String    @id @default(cuid())
  type               ConvType  @default(DIRECT)
  groupName          String?
  groupAvatar        String?
  groupAdminId       String?
  lastMessageAt      DateTime?
  lastMessagePreview String?
  createdAt          DateTime  @default(now())
  participants       ConversationMember[]
  messages           Message[]
  groupKeys          GroupKey[]

  @@index([lastMessageAt])
}

model ConversationMember {
  id             String       @id @default(cuid())
  conversationId String
  userId         String
  joinedAt       DateTime     @default(now())
  lastReadAt     DateTime?
  isMuted        Boolean      @default(false)
  isArchived     Boolean      @default(false)
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  user           User         @relation(fields: [userId], references: [id])

  @@unique([conversationId, userId])
  @@index([userId])
}

model Message {
  id               String        @id @default(cuid())
  conversationId   String
  senderId         String
  type             MessageType   @default(TEXT)
  encryptedContent String?
  plainContent     String?
  amountUsdc       Float?
  amountTzs        Float?
  stellarTxId      String?
  paymentStatus    PaymentStatus?
  paymentNote      String?
  mediaUrl         String?
  mediaThumbUrl    String?
  mediaMimeType    String?
  replyToId        String?
  isDeleted        Boolean       @default(false)
  deletedAt        DateTime?
  deliveredAt      DateTime?
  createdAt        DateTime      @default(now())
  replyTo          Message?      @relation("Replies", fields: [replyToId], references: [id])
  replies          Message[]     @relation("Replies")
  conversation     Conversation  @relation(fields: [conversationId], references: [id])
  sender           User          @relation(fields: [senderId], references: [id])
  receipts         MessageReceipt[]

  @@index([conversationId, createdAt])
  @@index([senderId])
}

model MessageReceipt {
  id        String   @id @default(cuid())
  messageId String
  userId    String
  readAt    DateTime @default(now())
  message   Message  @relation(fields: [messageId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([messageId, userId])
}

model GroupKey {
  id             String       @id @default(cuid())
  conversationId String
  userId         String
  encryptedKey   String
  conversation   Conversation @relation(fields: [conversationId], references: [id])

  @@unique([conversationId, userId])
}

model BlockedUser {
  id        String   @id @default(cuid())
  blockerId String
  blockedId String
  createdAt DateTime @default(now())
  blocker   User     @relation("Blocker",  fields: [blockerId], references: [id])
  blocked   User     @relation("Blocked",  fields: [blockedId],  references: [id])

  @@unique([blockerId, blockedId])
}
