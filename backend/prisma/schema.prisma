// JIKO CONNECT — LPG cooking-gas logistics marketplace (Tanzania)
// Three-sided network: households (demand), suppliers/vendors (stock),
// riders (last-mile + middle-mile logistics — the core engine).
// No blockchain, no crypto. Mobile-money fintech + logistics only.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ──────────────────────────────────────────────────────────────────────

enum Role {
  HOUSEHOLD
  SUPPLIER
  RIDER
  ADMIN
}

enum KycStatus {
  PENDING
  SUBMITTED
  APPROVED
  REJECTED
}

enum ProductType {
  REFILL     // gas refill (exchange empty for full)
  CYLINDER   // brand-new full cylinder
  ACCESSORY  // regulator, burner, pipe, grill, hotplate
}

enum OrderStatus {
  PLACED         // household submitted
  ALERTED        // supplier notified
  ACCEPTED       // supplier confirmed stock + payment
  BROADCAST      // (legacy) open to nearby riders
  CLAIMED        // (legacy) a rider took the job
  RIDER_OFFERED  // supplier assigned a specific rider, awaiting accept
  RIDER_ACCEPTED // rider accepted → fee proposed to household
  FEE_CONFIRMED  // household confirmed the rider fee → live tracking
  PICKED         // rider collected from vendor
  DELIVERED      // dropped at household (awaiting confirm/rating)
  COMPLETED      // settled
  CANCELLED
}

enum DeliveryStatus {
  PENDING
  CLAIMED
  PICKED
  DELIVERED
  FAILED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum PaymentProvider {
  MPESA        // Vodacom M-Pesa TZ
  TIGOPESA     // Mixx by Yas
  AIRTELMONEY
  HALOPESA
  CARD
  CASH
}

enum PayoutStatus {
  PENDING
  PAID
  FAILED
}

enum RestockStatus {
  REQUESTED
  ACCEPTED
  IN_TRANSIT
  FULFILLED
  CANCELLED
}

enum CylinderStatus {
  WITH_SUPPLIER
  WITH_HOUSEHOLD
  IN_TRANSIT
  RETURNED
  RETIRED
}

enum RiderStatus {
  OFFLINE
  ONLINE
  ON_JOB
}

enum VehicleType {
  MOTORBIKE   // boda-boda / pikipiki
  BAJAJI      // three-wheeler
  CAR
  TRUCK
  BICYCLE
}

enum SupplierTier {
  FREE
  STANDARD
  PREMIUM
}

// ── Core ────────────────────────────────────────────────────────────────────────

model User {
  id              String    @id @default(cuid())
  phone           String    @unique
  pinHash         String
  role            Role      @default(HOUSEHOLD)
  name            String?
  email           String?
  profilePicUrl   String?

  region          String?   // Dar es Salaam, Mwanza, Arusha, Dodoma, Mbeya, Zanzibar...
  kycStatus       KycStatus @default(PENDING)
  kycName         String?
  kycIdType       String?
  kycIdNumber     String?
  kycSelfieUrl    String?   @db.Text   // KYC selfie (data URL / hosted)
  kycIdUrl        String?   @db.Text   // KYC ID document image

  isActive        Boolean   @default(true)
  isFrozen        Boolean   @default(false)
  isAdmin         Boolean   @default(false)

  // Login lockout
  failedLoginCount Int      @default(0)
  lockedUntil      DateTime?

  isOnline        Boolean   @default(false)
  lastSeenAt      DateTime?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  refreshTokens     RefreshToken[]
  notifications     Notification[]
  pushSubscriptions PushSubscription[]
  addresses         Address[]
  supplierProfile   SupplierProfile?
  riderProfile      RiderProfile?
  orders            Order[]            @relation("HouseholdOrders")
  deliveries        Delivery[]         @relation("RiderDeliveries")
  payouts           Payout[]
  reviews           Review[]           @relation("ReviewAuthor")
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Address {
  id        String   @id @default(cuid())
  userId    String
  label     String   @default("Home")
  lat       Float
  lng       Float
  street    String?
  ward      String?
  district  String?
  region    String?
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders    Order[]

  @@index([userId])
}

// ── Supplier / Vendor ────────────────────────────────────────────────────────────

model SupplierProfile {
  id            String       @id @default(cuid())
  userId        String       @unique
  businessName  String
  phone         String
  logoUrl       String?
  region        String
  district      String?
  ward          String?
  lat           Float?
  lng           Float?
  isOpen        Boolean      @default(true)
  isVerified    Boolean      @default(false)
  acceptsCash   Boolean      @default(true)
  acceptsMobile Boolean      @default(true)
  tier          SupplierTier @default(FREE)
  featured      Boolean      @default(false)
  rating        Float        @default(0)
  ratingCount   Int          @default(0)
  distributor   String?      // upstream depot/distributor name (middle-mile)
  createdAt     DateTime     @default(now())

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  inventory       Inventory[]
  orders          Order[]
  restockRequests RestockRequest[]

  @@index([region, isOpen])
}

// ── Rider / Logistics ────────────────────────────────────────────────────────────

model RiderProfile {
  id              String      @id @default(cuid())
  userId          String      @unique
  vehicleType     VehicleType @default(MOTORBIKE)
  plateNo         String?
  region          String
  status          RiderStatus @default(OFFLINE)
  currentLat      Float?
  currentLng      Float?
  isVerified      Boolean     @default(false)
  rating          Float       @default(0)
  ratingCount     Int         @default(0)
  totalDeliveries Int         @default(0)
  totalEarnings   Float       @default(0)
  createdAt       DateTime    @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([region, status])
}

// ── Catalog ──────────────────────────────────────────────────────────────────────

model Product {
  id        String      @id @default(cuid())
  brand     String      // Taifa Gas, Oryx, Lake Gas, O-Gas, Manjis, Camel Gas
  name      String
  type      ProductType @default(REFILL)
  sizeKg    Float?      // 6, 15, 38, 45  (null for accessory)
  imageUrl  String?
  createdAt DateTime    @default(now())

  inventory  Inventory[]
  orderItems OrderItem[]

  @@index([brand, type])
}

model Inventory {
  id          String  @id @default(cuid())
  supplierId  String
  productId   String
  price       Float   // TZS
  stock       Int     @default(0)
  isAvailable Boolean @default(true)

  supplier SupplierProfile @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  product  Product         @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([supplierId, productId])
  @@index([productId])
}

// ── Orders ───────────────────────────────────────────────────────────────────────

model Order {
  id               String      @id @default(cuid())
  orderNo          String      @unique
  householdId      String
  supplierId       String
  addressId        String
  status           OrderStatus @default(PLACED)

  itemsTotal       Float       @default(0)
  deliveryFee      Float       @default(0)
  surgeMultiplier  Float       @default(1)
  total            Float       @default(0)
  commissionPct    Float       @default(0)
  commissionAmount Float       @default(0)

  note             String?
  placedAt         DateTime    @default(now())
  acceptedAt       DateTime?
  deliveredAt      DateTime?
  completedAt      DateTime?
  cancelledAt      DateTime?
  cancelReason     String?

  household User            @relation("HouseholdOrders", fields: [householdId], references: [id])
  supplier  SupplierProfile @relation(fields: [supplierId], references: [id])
  address   Address         @relation(fields: [addressId], references: [id])
  items     OrderItem[]
  delivery  Delivery?
  payment   Payment?
  review    Review?

  @@index([householdId, status])
  @@index([supplierId, status])
  @@index([status, placedAt])
}

model OrderItem {
  id          String  @id @default(cuid())
  orderId     String
  productId   String
  productName String  // snapshot
  brand       String
  sizeKg      Float?
  qty         Int     @default(1)
  unitPrice   Float
  lineTotal   Float

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([orderId])
}

model Delivery {
  id             String         @id @default(cuid())
  orderId        String         @unique
  riderId        String?
  status         DeliveryStatus @default(PENDING)
  riderFee       Float          @default(0)

  pickupLat      Float?
  pickupLng      Float?
  dropLat        Float?
  dropLng        Float?
  riderLat       Float?
  riderLng       Float?
  lastLocationAt DateTime?

  otp            String?
  proofPhotoUrl  String?
  claimedAt      DateTime?
  pickedAt       DateTime?
  deliveredAt    DateTime?

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  rider User? @relation("RiderDeliveries", fields: [riderId], references: [id])

  @@index([riderId, status])
  @@index([status])
}

// ── Payments / Payouts ───────────────────────────────────────────────────────────

model Payment {
  id          String          @id @default(cuid())
  orderId     String          @unique
  provider    PaymentProvider @default(MPESA)
  amount      Float
  currency    String          @default("TZS")
  status      PaymentStatus   @default(PENDING)
  providerRef String?
  phone       String?
  createdAt   DateTime        @default(now())
  paidAt      DateTime?

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([providerRef])
}

model Payout {
  id          String       @id @default(cuid())
  userId      String
  orderId     String?
  role        String       // SUPPLIER | RIDER | PLATFORM
  amount      Float
  status      PayoutStatus @default(PENDING)
  provider    String?
  providerRef String?
  createdAt   DateTime     @default(now())
  paidAt      DateTime?

  user User @relation(fields: [userId], references: [id])

  @@index([userId, status])
}

// ── Supply-chain (middle-mile restock) ──────────────────────────────────────────

model RestockRequest {
  id           String        @id @default(cuid())
  supplierId   String
  productId    String?
  distributor  String?
  qty          Int
  status       RestockStatus @default(REQUESTED)
  note         String?
  riderId      String?
  fee          Float?
  createdAt    DateTime      @default(now())
  fulfilledAt  DateTime?

  supplier SupplierProfile @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@index([supplierId, status])
}

// ── Reviews ──────────────────────────────────────────────────────────────────────

model Review {
  id             String   @id @default(cuid())
  orderId        String   @unique
  authorId       String
  supplierId     String?
  riderId        String?
  supplierRating Int?     // 1..5
  riderRating    Int?     // 1..5
  comment        String?
  createdAt      DateTime @default(now())

  order  Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  author User  @relation("ReviewAuthor", fields: [authorId], references: [id])
}

// ── Cylinder registry (plain DB, no chain) ──────────────────────────────────────

model Cylinder {
  id        String         @id @default(cuid())
  serial    String         @unique
  brand     String
  sizeKg    Float
  ownerId   String?        // current holder (household / supplier user id)
  status    CylinderStatus @default(WITH_SUPPLIER)
  createdAt DateTime       @default(now())

  @@index([ownerId])
}

// ── EWURA price regulation ───────────────────────────────────────────────────────

model PriceCap {
  id        String   @id @default(cuid())
  region    String
  productId String?
  maxPrice  Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([region, productId])
}

// ── Notifications ────────────────────────────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  body      String
  type      String
  isRead    Boolean  @default(false)
  data      Json?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([userId, createdAt])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dhKey String
  authKey   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
