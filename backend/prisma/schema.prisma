generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ──────────────────────────────────────────────────────────────────────

enum KycStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TxType {
  DEPOSIT
  WITHDRAWAL
  SEND
  RECEIVE
  FEE
  SAVINGS_DEPOSIT
  SAVINGS_WITHDRAW
  BILL_PAYMENT
  BANK_WITHDRAWAL
}

enum TxStatus {
  PENDING
  CONFIRMED
  FAILED
}

enum Frequency {
  DAILY
  WEEKLY
  BIWEEKLY
  MONTHLY
}

enum ClaimStatus {
  PENDING
  CLAIMED
  EXPIRED
  RETURNED
}

enum StakeStatus {
  ACTIVE
  UNLOCKED
  WITHDRAWN
}

enum ChamaStatus {
  FORMING
  ACTIVE
  COMPLETED
  PAUSED
}

enum LoanStatus {
  OPEN
  FUNDED
  REPAID
  DEFAULTED
}

enum RewardTier {
  BRONZE
  SILVER
  GOLD
  PLATINUM
}

// ── Core models ───────────────────────────────────────────────────────────────

model User {
  id              String    @id @default(cuid())
  phone           String    @unique
  pinHash         String
  stellarPubKey   String    @unique
  stellarSecret   String
  kycStatus       KycStatus @default(PENDING)
  kycName         String?
  kycIdType       String?
  kycIdNumber     String?
  dailyVolumeTzs  Float     @default(0)
  dailyVolumeDate DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  transactions       Transaction[]
  refreshTokens      RefreshToken[]
  bankAccounts       BankAccount[]
  savingsPosition    SavingsPosition?
  billPayments       BillPayment[]
  scheduledPayments  ScheduledPayment[]
  pushSubscriptions  PushSubscription[]
  notifications      Notification[]
  stakePosition      StakePosition?
  chamasAdmin        Chama[]
  chamaMembers       ChamaMember[]
  loansGiven         LoanListing[]     @relation("LenderLoans")
  loansTaken         LoanListing[]     @relation("BorrowerLoans")
  creditScore        CreditScore?
  rewardPoints       RewardPoints?
  virtualCard        VirtualCard?
}

model Transaction {
  id          String   @id @default(cuid())
  userId      String
  type        TxType
  status      TxStatus @default(PENDING)
  amountTzs   Float?
  amountUsdc  Float?
  amountXlm   Float?
  stellarTxId String?
  mpesaTxId   String?
  toAddress   String?
  memo        String?
  errorMsg    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([mpesaTxId])
  @@index([stellarTxId])
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ExchangeRateCache {
  id        String   @id @default("singleton")
  usdToTzs  Float
  updatedAt DateTime @updatedAt
}

// ── Feature 1: Bank Withdrawal ────────────────────────────────────────────────

model BankAccount {
  id            String   @id @default(cuid())
  userId        String
  bankName      String
  accountNumber String
  swiftCode     String
  accountName   String
  isVerified    Boolean  @default(false)
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

// ── Feature 2: Savings ────────────────────────────────────────────────────────

model SavingsPosition {
  id           String    @id @default(cuid())
  userId       String    @unique
  principal    Float     @default(0)
  yieldEarned  Float     @default(0)
  depositedAt  DateTime?
  lastYieldAt  DateTime?
  user         User      @relation(fields: [userId], references: [id])
}

// ── Feature 3: Bill Payments ──────────────────────────────────────────────────

model BillPayment {
  id            String   @id @default(cuid())
  userId        String
  billerName    String
  billerCode    String
  accountNumber String
  amountTzs     Float
  amountUsdc    Float
  reference     String?
  token         String?  // LUKU electricity token
  status        TxStatus @default(PENDING)
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

// ── Feature 4: Contacts / Pending Claims ─────────────────────────────────────

model PendingClaim {
  id         String      @id @default(cuid())
  senderId   String
  toPhone    String
  claimToken String      @unique
  amountUsdc Float
  expiresAt  DateTime
  claimedAt  DateTime?
  status     ClaimStatus @default(PENDING)
  createdAt  DateTime    @default(now())

  @@index([claimToken])
  @@index([toPhone])
}

// ── Feature 5: Scheduled Payments ────────────────────────────────────────────

model ScheduledPayment {
  id             String    @id @default(cuid())
  userId         String
  toAddress      String
  toPhone        String?
  toName         String?
  amount         Float
  asset          String    @default("USDC")
  frequency      Frequency
  nextRunAt      DateTime
  endDate        DateTime?
  memo           String?
  isActive       Boolean   @default(true)
  executionCount Int       @default(0)
  lastRunAt      DateTime?
  createdAt      DateTime  @default(now())
  user           User      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([nextRunAt, isActive])
}

// ── Feature 6: Push Notifications ────────────────────────────────────────────

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dhKey String
  authKey   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  body      String
  type      String
  isRead    Boolean  @default(false)
  data      Json?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([userId, createdAt])
}

// ── Phase 3 Models ────────────────────────────────────────────────────────────

model StakePosition {
  id           String      @id @default(cuid())
  userId       String      @unique
  amountUsdc   Float
  lockDays     Int
  apyBps       Int
  stakedAt     DateTime
  unlockAt     DateTime
  yieldClaimed Float       @default(0)
  contractKey  String?
  status       StakeStatus @default(ACTIVE)
  user         User        @relation(fields: [userId], references: [id])
}

model Chama {
  id               String      @id @default(cuid())
  name             String
  contractId       String?
  adminId          String
  contributionUsdc Float
  frequencyDays    Int
  currentRound     Int         @default(0)
  status           ChamaStatus @default(FORMING)
  nextDueAt        DateTime?
  createdAt        DateTime    @default(now())
  members          ChamaMember[]
  admin            User        @relation(fields: [adminId], references: [id])
}

model ChamaMember {
  id          String  @id @default(cuid())
  chamaId     String
  userId      String
  position    Int
  hasReceived Boolean @default(false)
  chama       Chama   @relation(fields: [chamaId], references: [id])
  user        User    @relation(fields: [userId], references: [id])

  @@unique([chamaId, userId])
  @@index([chamaId])
}

model LoanListing {
  id           String     @id @default(cuid())
  lenderId     String
  amountUsdc   Float
  interestBps  Int
  durationDays Int
  status       LoanStatus @default(OPEN)
  borrowerId   String?
  contractLoanId Int?
  createdAt    DateTime   @default(now())
  dueAt        DateTime?
  lender       User       @relation("LenderLoans",   fields: [lenderId],   references: [id])
  borrower     User?      @relation("BorrowerLoans", fields: [borrowerId], references: [id])

  @@index([status])
  @@index([lenderId])
}

model CreditScore {
  id           String   @id @default(cuid())
  userId       String   @unique
  score        Int      @default(40)
  loansRepaid  Int      @default(0)
  defaults     Int      @default(0)
  monthsActive Int      @default(0)
  updatedAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id])
}

model RewardPoints {
  id           String     @id @default(cuid())
  userId       String     @unique
  balance      Int        @default(0)
  totalEarned  Int        @default(0)
  tier         RewardTier @default(BRONZE)
  streak       Int        @default(0)
  lastActivity DateTime?
  user         User       @relation(fields: [userId], references: [id])
}

model VirtualCard {
  id           String   @id @default(cuid())
  userId       String   @unique
  cardRef      String   @unique
  maskedNumber String
  expiryMonth  Int
  expiryYear   Int
  status       String   @default("active")
  dailyLimit   Float    @default(500)
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id])
}

model RateHistory {
  id        String   @id @default(cuid())
  usdToTzs  Float
  date      DateTime @unique
  createdAt DateTime @default(now())
}
